{
  "name": "Ecommerce",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/ecommerce",
  "runServices": ["db", "pgadmin"],
  "forwardPorts": [5051],
  "postCreateCommand": "pip install -r requirements.txt && python .devcontainer/ensure_postgres_db.py",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "mechatroner.rainbow-csv"
      ]
    }
  }
}
